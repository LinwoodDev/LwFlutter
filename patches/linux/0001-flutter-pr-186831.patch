From 3cd0d1d9ea9d61e618a5a4f88ec133ce94cb2b0e Mon Sep 17 00:00:00 2001
From: CodeDoctorDE <codedoctor@linwood.dev>
Date: Wed, 20 May 2026 22:56:24 +0200
Subject: [PATCH] Add linux stylus pressure and rotation support

---
 engine/src/flutter/shell/platform/linux/fl_engine.cc      | 13 ++++-
 engine/src/flutter/shell/platform/linux/fl_engine_test.cc |  2 +-
 engine/src/flutter/shell/platform/linux/fl_engine_private.h |  5 +-
 engine/src/flutter/shell/platform/linux/fl_pointer_manager.cc | 61 +++++++++++++++------
 engine/src/flutter/shell/platform/linux/fl_pointer_manager.h  | 32 +++++++++--
 engine/src/flutter/shell/platform/linux/fl_pointer_manager_test.cc | 94 ++++++++++++++--------------
 engine/src/flutter/shell/platform/linux/fl_scrolling_manager.cc |  2 +-
 engine/src/flutter/shell/platform/linux/fl_view.cc         | 25 +++++++--
 8 files changed, 156 insertions(+), 78 deletions(-)

diff --git a/engine/src/flutter/shell/platform/linux/fl_engine.cc b/engine/src/flutter/shell/platform/linux/fl_engine.cc
index 6ccdc39d..8002c324 100644
--- a/engine/src/flutter/shell/platform/linux/fl_engine.cc
+++ b/engine/src/flutter/shell/platform/linux/fl_engine.cc
@@ -1182,7 +1182,8 @@ void fl_engine_send_mouse_pointer_event(FlEngine* self,
                                         FlutterPointerDeviceKind device_kind,
                                         double scroll_delta_x,
                                         double scroll_delta_y,
-                                        int64_t buttons) {
+                                        int64_t buttons,
+                                        FlPointerDeviceState device_state) {
   g_return_if_fail(FL_IS_ENGINE(self));
 
   if (self->engine == nullptr) {
@@ -1204,6 +1205,16 @@ void fl_engine_send_mouse_pointer_event(FlEngine* self,
   fl_event.buttons = buttons;
   fl_event.device = kMousePointerDeviceId;
   fl_event.view_id = view_id;
+  // GDK reports tablet pressure through GDK_AXIS_PRESSURE. The GDK input
+  // device documentation defines pressure as normalized from 0.0 to 1.0,
+  // which matches Flutter's expected pressure range.
+  // See: https://refspecs.linuxbase.org/gtk/2.6/gdk/gdk-Input-Devices.html
+  fl_event.pressure = device_state.pressure;
+  fl_event.pressure_min = 0.0;
+  fl_event.pressure_max = 1.0;
+  // GTK reports rotation in degrees, so convert it to radians for
+  // FlutterPointerEvent.rotation.
+  fl_event.rotation = device_state.rotation * G_PI / 180.0;
   if (self->embedder_api.SendPointerEvent(self->engine, &fl_event, 1) !=
       kSuccess) {
     g_warning("Failed to send pointer event");
diff --git a/engine/src/flutter/shell/platform/linux/fl_engine_test.cc b/engine/src/flutter/shell/platform/linux/fl_engine_test.cc
