+/**
+ * FlPointerDeviceState:
+ * @pressure: the pressure of the device.
+ * @rotation: the rotation of the device.
+ *
+ * A structure representing the state of a pointer device.
+ */
+typedef struct {
+  double pressure;
+  double rotation;
+} FlPointerDeviceState;
+
