   fl_engine_send_mouse_pointer_event(engine, 1, kDown, 1234567890, 800, 600,
                                      kFlutterPointerDeviceKindMouse, 1.2, -3.4,
-                                     kFlutterPointerButtonMouseSecondary);
+                                     kFlutterPointerButtonMouseSecondary, {});
 
   EXPECT_TRUE(called);
 }
